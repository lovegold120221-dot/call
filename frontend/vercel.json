{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "devCommand": "npm run dev",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "VITE_LIVEKIT_URL": "@livekit_url",
    "VITE_LIVEKIT_API_KEY": "@livekit_api_key",
    "VITE_GOOGLE_API_KEY": "@google_api_key"
  }
}
